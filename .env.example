# Secure Mail Automation - Environment Example
# Copy to .env and adjust values.

# Required for push stack
MAIL_PUSH_TOKEN=CHANGE_ME_MAIL_PUSH_TOKEN
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_SUBSCRIPTION_NAME=gmail-watch-push
ASSISTANT_EMAIL=assistant@example.com

# Optional: custom keyring passphrase file for gog
GOG_KEYRING_PASSWORD_FILE=$HOME/.config/gogcli/.keyring_pass
